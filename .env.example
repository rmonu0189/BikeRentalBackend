APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=YOUR_DB_NAME
DB_USER=YOUR_DB_USER
DB_PASS=YOUR_DB_PASSWORD

JWT_SECRET=YOUR_JWT_SECRET
JWT_ISSUER=YOUR_JWT_ISSUER
JWT_AUDIENCE=YOUR_JWT_AUDIENCE
JWT_ACCESS_TTL_SECONDS=900
JWT_TTL_SECONDS=3600

# CORS settings
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

# Phone OTP Settings
OTP_LENGTH=6
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_LOG_TO_FILE=true
OTP_RETURN_CODE_IN_RESPONSE=true
OTP_ENABLE_FIXED_TEST_OTP=false
OTP_TEST_CODE=XXXXXX
OTP_TEST_PHONES=91XXXXXXXXXX

# Vehicle Settings
VEHICLE_VERIFICATION_REQUIRED=true
